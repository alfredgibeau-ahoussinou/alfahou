# Copier vers .env — ne jamais committer le vrai token

# === Recommandé 2026 : Groq + GPT-OSS 120B (recherche web + code intégrés) ===
# https://console.groq.com/keys
ALFAHOU_LLM_PROVIDER=groq
ALFAHOU_LLM_MODEL=openai/gpt-oss-120b
GROQ_API_KEY=gsk_xxxxxxxx

# Variantes Groq :
# ALFAHOU_LLM_MODEL=openai/gpt-oss-20b          # plus rapide
# ALFAHOU_LLM_PROVIDER=compound                 # agent multi-outils (web, code, Wolfram)
# ALFAHOU_LLM_MODEL=groq/compound
# ALFAHOU_LLM_MODEL=qwen/qwen3.6-27b            # preview Qwen 3.6

# === Option : OpenRouter (Gemini, Claude, DeepSeek, Kimi, etc.) ===
# https://openrouter.ai/keys
# ALFAHOU_LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-xxxxxxxx
# ALFAHOU_LLM_MODEL=openai/gpt-oss-120b

# === Option : Hugging Face Inference Providers ===
# https://huggingface.co/settings/tokens
# ALFAHOU_LLM_PROVIDER=hf
# HF_TOKEN=hf_xxxxxxxx
# ALFAHOU_LLM_MODEL=Qwen/Qwen3-32B
# ALFAHOU_LLM_BASE_URL=https://router.huggingface.co/v1
