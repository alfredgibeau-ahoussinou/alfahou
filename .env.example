# Copier vers .env — ne jamais committer le vrai token

# Option A (recommandé si crédits HF épuisés) : Groq gratuit + Llama open-source
# https://console.groq.com/keys
ALFAHOU_LLM_PROVIDER=auto
GROQ_API_KEY=gsk_xxxxxxxx

# Option B : Hugging Face Inference Providers
# https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxxxxxx
# ALFAHOU_LLM_API_KEY=hf_xxxxxxxx
# ALFAHOU_LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
# ALFAHOU_LLM_BASE_URL=https://router.huggingface.co/v1
