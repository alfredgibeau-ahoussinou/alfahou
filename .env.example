# Copier vers .env — ne jamais committer le vrai token

# Hugging Face (recommandé — Inference Providers, modèles open-source)
# Créer un token : https://huggingface.co/settings/tokens
# Permission : Make calls to Inference Providers
ALFAHOU_LLM_PROVIDER=hf
ALFAHOU_LLM_API_KEY=hf_xxxxxxxx
ALFAHOU_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
ALFAHOU_LLM_BASE_URL=https://router.huggingface.co/v1

# Alternative rapide : Groq (Llama open-source)
# ALFAHOU_LLM_PROVIDER=groq
# ALFAHOU_LLM_API_KEY=gsk_xxxxxxxx
# ALFAHOU_LLM_MODEL=llama-3.3-70b-versatile

# Ou aliases standards
# HF_TOKEN=hf_xxxxxxxx
# GROQ_API_KEY=gsk_xxxxxxxx
