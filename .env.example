# Copier vers .env — ne jamais committer le vrai token

# === Mode auto (recommandé) : bascule entre plusieurs APIs si l’une est saturée ===
ALFAHOU_LLM_PROVIDER=auto
ALFAHOU_LLM_MODEL=openai/gpt-oss-20b

# 1) Groq (rapide + recherche web sur GPT-OSS)
# https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxx

# 2) OpenRouter = l’équivalent « plein de modèles » (Gemini, Claude, DeepSeek, Llama…)
# https://openrouter.ai/keys  → colle sk-or-v1-…
# OPENROUTER_API_KEY=sk-or-xxxxxxxx

# 3) Hugging Face (optionnel)
# HF_TOKEN=hf_xxxxxxxx

# Forcer un seul fournisseur :
# ALFAHOU_LLM_PROVIDER=groq|openrouter|hf|compound|ollama
